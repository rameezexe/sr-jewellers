# ─────────────────────────────────────────────────────────────────────────
#  Copy this file to ".env" and fill in real values.
#  Never commit .env (it's gitignored).
# ─────────────────────────────────────────────────────────────────────────

# --- Database: Neon Postgres (use the POOLED connection string) ---
# Create a free DB at https://neon.tech and copy the "Pooled connection" URL.
# Must keep ?sslmode=require. We talk to it over HTTPS/WebSocket (port 443).
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"

# --- Admin login (seeded into the DB by `npm run db:setup`) ---
ADMIN_EMAIL="mom@example.com"
ADMIN_PASSWORD="change-this-now"
ADMIN_NAME="Mom"

# --- Session signing secret (any random 32+ char string) ---
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="replace-with-a-long-random-string"

# --- Payments: UPI (no gateway / no KYC) ---
# Your UPI ID (VPA), e.g. "yourname@oksbi". Customers pay you directly and the
# QR is generated from this. Leave blank to offer only Cash on Delivery.
UPI_ID=""
# Name shown in the customer's UPI app; defaults to the shop name if blank.
UPI_PAYEE_NAME="SR Jewellers"

# --- Cloudinary (https://cloudinary.com — free tier) ---
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# --- Email: Gmail (free) ---
# Use a Google "App Password" (Google Account → Security → 2-Step Verification →
# App passwords), NOT your normal password. Leave blank to skip emails.
GMAIL_USER="yourshop@gmail.com"
GMAIL_APP_PASSWORD=""
# Optional "From" label; defaults to "SR Jewellers <GMAIL_USER>" if blank.
EMAIL_FROM=""
# Where the "new order" alert goes; defaults to GMAIL_USER if blank.
OWNER_EMAIL=""

# --- Public site URL (used in emails / SEO). Set on Vercel in production. ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
